<Window x:Class="SamhainSecurity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Samhain Security"
        Height="820"
        Width="1320"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#171A22"
        Loaded="Window_Loaded"
        Activated="Window_Activated">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#D6A72D" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#40351B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#252936" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#202431" />
        <SolidColorBrush x:Key="LineBrush" Color="#3B4153" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A8B0C2" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#11151D" />
        <SolidColorBrush x:Key="NavTextBrush" Color="#D7DCE8" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#173D35" />
        <SolidColorBrush x:Key="SuccessTextBrush" Color="#64D6B5" />
        <SolidColorBrush x:Key="WarningBrush" Color="#3E341F" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#F0C869" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#432723" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#FF8D7A" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="DailyLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#51605B" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#2D3241" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#2D3241" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#2D3241" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#343A4A" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource NavTextBrush}" />
        </Style>

        <Style x:Key="PowerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="132" />
            <Setter Property="Height" Value="132" />
            <Setter Property="MinHeight" Value="132" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="46" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PowerChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="66"
                                BorderBrush="#F4CF71"
                                BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PowerChrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="Samhain Security"
                               Foreground="#FFFFFF"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VersionTextBlock"
                               Text="0.0.1"
                               Foreground="#9AA4B2"
                               FontSize="13"
                               Margin="1,4,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <Button x:Name="NewProfileButton"
                            Content="Новый профиль"
                            Click="NewProfileButton_Click"
                            Margin="0,0,0,8" />
                    <Button x:Name="DeleteProfileButton"
                            Content="Удалить"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="DeleteProfileButton_Click" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Серверы"
                               Foreground="#7F889B"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <Button x:Name="AllServersCategoryButton"
                            Content="Все серверы"
                            Tag="all"
                            Style="{StaticResource NavButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="FavoriteServersCategoryButton"
                            Content="Избранные"
                            Tag="favorite"
                            Style="{StaticResource NavButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="FastServersCategoryButton"
                            Content="Быстрые"
                            Tag="fast"
                            Style="{StaticResource NavButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="RecentServersCategoryButton"
                            Content="Последние"
                            Tag="recent"
                            Style="{StaticResource NavButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="VlessServersCategoryButton"
                            Content="VLESS"
                            Tag="vless"
                            Style="{StaticResource NavButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="AwgServersCategoryButton"
                            Content="AWG"
                            Tag="awg"
                            Style="{StaticResource NavButtonStyle}"
                            Click="ServerCategoryButton_Click" />

                    <TextBlock Text="Профили"
                               Foreground="#7F889B"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,18,0,8" />
                    <ListBox x:Name="ProfilesListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#FFFFFF"
                             SelectionChanged="ProfilesListBox_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Padding" Value="12" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#FFFFFF"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ServerAddress}"
                                               Foreground="#AEB7C2"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="190" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="ServerCatalogTitleTextBlock"
                               Text="Все серверы"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Готово"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RunAsAdminButton"
                            Content="Админ"
                            Click="RunAsAdminButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="ServiceButton"
                            Content="Служба"
                            Click="ServiceButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="DiagnosticsButton"
                            Content="Диагностика"
                            Click="DiagnosticsButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="ExportDiagnosticsButton"
                            Content="Экспорт"
                            Click="ExportDiagnosticsButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="RefreshStatusButton"
                            Content="Статус"
                            Click="RefreshStatusButton_Click" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Padding="22">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border x:Name="FirstRunPanel"
                                Background="{StaticResource SuccessBrush}"
                                BorderBrush="#2D7D69"
                                BorderThickness="1"
                                Padding="16"
                                Margin="0,0,0,20"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="86" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Быстрый старт"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Вставьте ссылку подключения, обновите подписку и нажмите Подключить."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Из буфера"
                                        VerticalAlignment="Center"
                                        Click="FirstRunPasteButton_Click" />

                                <Button Grid.Column="4"
                                        Content="Скрыть"
                                        VerticalAlignment="Center"
                                        Click="DismissFirstRunButton_Click" />
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                Padding="14"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Подписка"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="88" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ссылка подключения" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox x:Name="SubscriptionUrlTextBox" />
                                    </StackPanel>

                                    <Button x:Name="RefreshSubscriptionButton"
                                            Grid.Column="2"
                                            Content="Обновить"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            VerticalAlignment="Bottom"
                                            Click="RefreshSubscriptionButton_Click" />

                                    <Button x:Name="RefreshAllSubscriptionsButton"
                                            Grid.Column="4"
                                            Content="Все"
                                            VerticalAlignment="Bottom"
                                            Click="RefreshAllSubscriptionsButton_Click" />

                                    <Button x:Name="PasteSubscriptionButton"
                                            Grid.Column="6"
                                            Content="Буфер"
                                            VerticalAlignment="Bottom"
                                            Click="PasteSubscriptionButton_Click" />

                                    <Button x:Name="DeleteSubscriptionButton"
                                            Grid.Column="8"
                                            Content="Удалить"
                                            Style="{StaticResource DangerButtonStyle}"
                                            VerticalAlignment="Bottom"
                                            Click="DeleteSubscriptionButton_Click" />
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="84" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Сохраненные подписки" Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="SubscriptionSelectorComboBox"
                                                  DisplayMemberPath="SelectorName"
                                                  SelectionChanged="SubscriptionSelectorComboBox_SelectionChanged" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Сервер" Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="ServerSelectorComboBox"
                                                  SelectionChanged="ServerSelectorComboBox_SelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding StatusLabel}"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12"
                                                                       Margin="10,0,0,0" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding Details}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding MenuLabel}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <Button x:Name="FavoriteServerButton"
                                            Grid.Column="4"
                                            Content="Избранное"
                                            VerticalAlignment="Bottom"
                                            Click="FavoriteServerButton_Click" />

                                    <Button x:Name="BestServerButton"
                                            Grid.Column="6"
                                            Content="Лучший"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            VerticalAlignment="Bottom"
                                            Click="BestServerButton_Click" />

                                    <Button x:Name="ProbeServersButton"
                                            Grid.Column="8"
                                            Content="Проверить"
                                            VerticalAlignment="Bottom"
                                            Click="ProbeServersButton_Click" />

                                    <Button x:Name="ResetServerHealthButton"
                                            Grid.Column="10"
                                            Content="Сброс"
                                            VerticalAlignment="Bottom"
                                            Click="ResetServerHealthButton_Click" />
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="RecommendedServerButton"
                                            Grid.Column="0"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="12,10"
                                            Click="RecommendedServerButton_Click">
                                        <StackPanel>
                                            <TextBlock Text="Рекомендуем"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="RecommendedServerNameTextBlock"
                                                       Text="Нет серверов"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecommendedServerDetailTextBlock"
                                                       Text="Обновите подписку"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecommendedServerReasonTextBlock"
                                                       Text="Нет данных"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="FavoriteRecommendationButton"
                                            Grid.Column="2"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="12,10"
                                            Click="FavoriteRecommendationButton_Click">
                                        <StackPanel>
                                            <TextBlock Text="Избранный"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="FavoriteRecommendationNameTextBlock"
                                                       Text="Не выбран"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="FavoriteRecommendationDetailTextBlock"
                                                       Text="Отметьте сервер"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="FavoriteRecommendationReasonTextBlock"
                                                       Text="Нет данных"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="RecentServerButton"
                                            Grid.Column="4"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="12,10"
                                            Click="RecentServerButton_Click">
                                        <StackPanel>
                                            <TextBlock Text="Последний"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="RecentServerNameTextBlock"
                                                       Text="Пока пусто"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecentServerDetailTextBlock"
                                                       Text="После успешного подключения"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecentServerReasonTextBlock"
                                                       Text="Нет данных"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="4" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="92" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Поиск сервера" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox x:Name="ServerSearchTextBox"
                                                 KeyDown="ServerSearchTextBox_KeyDown"
                                                 TextChanged="ServerCatalogFilter_Changed" />
                                    </StackPanel>

                                    <CheckBox x:Name="FavoriteServersOnlyCheckBox"
                                              Grid.Column="2"
                                              Content="Только избранные"
                                              Foreground="{StaticResource TextBrush}"
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,0,10"
                                              Checked="ServerCatalogFilter_Changed"
                                              Unchecked="ServerCatalogFilter_Changed" />

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Сортировка" Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="ServerSortComboBox"
                                                  SelectionChanged="ServerSortComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Умная" Tag="smart" />
                                            <ComboBoxItem Content="Быстрые" Tag="latency" />
                                            <ComboBoxItem Content="Избранные" Tag="favorite" />
                                            <ComboBoxItem Content="Недавние" Tag="recent" />
                                            <ComboBoxItem Content="По имени" Tag="name" />
                                        </ComboBox>
                                    </StackPanel>

                                    <Button x:Name="ClearServerFiltersButton"
                                            Grid.Column="6"
                                            Content="Сбросить"
                                            VerticalAlignment="Bottom"
                                            Click="ClearServerFiltersButton_Click" />
                                </Grid>

                                <ListView x:Name="ServersListView"
                                          Grid.Row="5"
                                          Height="300"
                                          Margin="0,12,0,0"
                                          Background="{StaticResource PanelBrush}"
                                          Foreground="{StaticResource TextBrush}"
                                          BorderBrush="{StaticResource LineBrush}"
                                          BorderThickness="1"
                                          KeyDown="ServersListView_KeyDown"
                                          MouseDoubleClick="ServersListView_MouseDoubleClick"
                                          PreviewMouseRightButtonDown="ServersListView_PreviewMouseRightButtonDown"
                                          SelectionChanged="ServersListView_SelectionChanged">
                                    <ListView.ContextMenu>
                                        <ContextMenu Opened="ServersListContextMenu_Opened">
                                            <MenuItem Header="Подключить"
                                                      Click="ServerContextConnectMenuItem_Click" />
                                            <MenuItem x:Name="ServerContextFavoriteMenuItem"
                                                      Header="В избранное"
                                                      Click="ServerContextFavoriteMenuItem_Click" />
                                            <MenuItem Header="Копировать адрес"
                                                      Click="ServerContextCopyEndpointMenuItem_Click" />
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Сервер" Width="320">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,4">
                                                            <Border DockPanel.Dock="Left"
                                                                    Width="34"
                                                                    Height="34"
                                                                    CornerRadius="17"
                                                                    Background="{StaticResource AccentSoftBrush}"
                                                                    Margin="0,0,10,0">
                                                                <TextBlock Text="{Binding BadgeText}"
                                                                           Foreground="{StaticResource AccentBrush}"
                                                                           FontWeight="SemiBold"
