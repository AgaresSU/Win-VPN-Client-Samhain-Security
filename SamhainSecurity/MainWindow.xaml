<Window x:Class="SamhainSecurity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Samhain Security"
        Height="780"
        Width="1180"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#16836F" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#D9E0E6" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="TextBrush" Color="#18212F" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#171A21" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#DFF6EE" />
        <SolidColorBrush x:Key="SuccessTextBrush" Color="#116956" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF0D9" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#8A4B0F" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE8E5" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#A53A2A" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#E8EDF2" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFE8E5" />
            <Setter Property="Foreground" Value="#A53A2A" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel Margin="22">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="Samhain Security"
                               Foreground="#FFFFFF"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VersionTextBlock"
                               Text="0.0.1"
                               Foreground="#9AA4B2"
                               FontSize="13"
                               Margin="1,4,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <Button x:Name="NewProfileButton"
                            Content="Новый профиль"
                            Click="NewProfileButton_Click"
                            Margin="0,0,0,8" />
                    <Button x:Name="DeleteProfileButton"
                            Content="Удалить"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="DeleteProfileButton_Click" />
                </StackPanel>

                <ListBox x:Name="ProfilesListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#FFFFFF"
                         SelectionChanged="ProfilesListBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Padding" Value="12" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#FFFFFF"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ServerAddress}"
                                           Foreground="#AEB7C2"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="190" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Профиль подключения"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Готово"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RunAsAdminButton"
                            Content="Админ"
                            Click="RunAsAdminButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="ServiceButton"
                            Content="Служба"
                            Click="ServiceButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="DiagnosticsButton"
                            Content="Диагностика"
                            Click="DiagnosticsButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="ExportDiagnosticsButton"
                            Content="Экспорт"
                            Click="ExportDiagnosticsButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="RefreshStatusButton"
                            Content="Статус"
                            Click="RefreshStatusButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="DisconnectButton"
                            Content="Отключить"
                            Click="DisconnectButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="ConnectButton"
                            Content="Подключить"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ConnectButton_Click" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Padding="22">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Название" Style="{StaticResource LabelTextStyle}" />
                                <TextBox x:Name="NameTextBox" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Протокол" Style="{StaticResource LabelTextStyle}" />
                                <DockPanel>
                                    <ComboBox x:Name="ProtocolComboBox"
                                              DockPanel.Dock="Left"
                                              Width="134"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectionChanged="ProtocolComboBox_SelectionChanged" />
                                    <Border x:Name="EngineStatusBadge"
                                            Background="{StaticResource SuccessBrush}"
                                            Padding="10,7"
                                            Margin="8,0,0,0"
                                            MinHeight="38">
                                        <TextBlock x:Name="EngineStatusTextBlock"
                                                   Text="Ready"
                                                   Foreground="{StaticResource SuccessTextBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Порт" Style="{StaticResource LabelTextStyle}" />
                                <TextBox x:Name="ServerPortTextBox" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Сервер" Style="{StaticResource LabelTextStyle}" />
                            <TextBox x:Name="ServerTextBox" />
                        </StackPanel>

                        <Grid x:Name="EnginePathPanel" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="EnginePathLabel"
                                           Text="Движок"
                                           Style="{StaticResource LabelTextStyle}" />
                                <TextBox x:Name="EnginePathTextBox"
                                         TextChanged="EnginePathTextBox_TextChanged" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="Обзор"
                                    VerticalAlignment="Bottom"
                                    Click="BrowseEngineButton_Click" />
                        </Grid>

                        <StackPanel x:Name="NativePanel" Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Тип туннеля" Style="{StaticResource LabelTextStyle}" />
                                    <ComboBox x:Name="TunnelTypeComboBox"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Пользователь" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="UserNameTextBox" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Пароль" Style="{StaticResource LabelTextStyle}" />
                                    <PasswordBox x:Name="PasswordBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="L2TP PSK" Style="{StaticResource LabelTextStyle}" />
                                    <PasswordBox x:Name="L2tpPskPasswordBox" />
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="SplitTunnelingCheckBox"
                                      Content="Split tunneling"
                                      Foreground="{StaticResource TextBrush}"
                                      Margin="0,16,0,0" />
                        </StackPanel>

                        <StackPanel x:Name="VlessRealityPanel" Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="VLESS URI" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="VlessUriTextBox" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Импорт"
                                        VerticalAlignment="Bottom"
                                        Click="ImportVlessButton_Click" />
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="UUID" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="VlessUuidTextBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Flow" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="VlessFlowTextBox" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Reality SNI" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityServerNameTextBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Fingerprint" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityFingerprintTextBox" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Reality public key" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityPublicKeyTextBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Short ID" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityShortIdTextBox" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="TunnelConfigPanel" Margin="0,18,0,0">
                            <TextBlock x:Name="TunnelConfigLabel"
                                       Text="WireGuard .conf"
                                       Style="{StaticResource LabelTextStyle}" />
                            <TextBox x:Name="TunnelConfigTextBox"
                                     Height="190"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     VerticalContentAlignment="Top" />
                        </StackPanel>

                        <Border Height="1"
                                Background="{StaticResource LineBrush}"
                                Margin="0,20,0,18" />

                        <StackPanel>
                            <TextBlock Text="Защита"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <CheckBox x:Name="KillSwitchCheckBox"
                                              Content="Kill switch"
                                              Foreground="{StaticResource TextBrush}"
                                              Margin="0,0,0,10" />
                                    <CheckBox x:Name="DnsLeakProtectionCheckBox"
                                              Content="DNS leak protection"
                                              Foreground="{StaticResource TextBrush}"
                                              Margin="0,0,0,10" />
                                    <CheckBox x:Name="AllowLanTrafficCheckBox"
                                              Content="Локальная сеть"
                                              Foreground="{StaticResource TextBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="DNS servers" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="DnsServersTextBox" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,14,0,0">
                                <Button x:Name="PreviewProtectionButton"
                                        Content="План"
                                        Click="PreviewProtectionButton_Click"
                                        Margin="0,0,8,0" />
                                <Button x:Name="ProtectionStatusButton"
                                        Content="Проверить"
                                        Click="ProtectionStatusButton_Click"
                                        Margin="0,0,8,0" />
                                <Button x:Name="RemoveProtectionButton"
                                        Content="Снять"
                                        Click="RemoveProtectionButton_Click"
                                        Margin="0,0,8,0" />
                                <Button x:Name="ApplyProtectionButton"
                                        Content="Применить"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="ApplyProtectionButton_Click" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,18,0,0">
                            <Button x:Name="SaveProfileButton"
                                    Content="Сохранить"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveProfileButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Padding="18"
                    Margin="0,18,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Журнал"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Margin="0,0,0,10" />
                    <TextBox x:Name="LogTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="#FAFBFC"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalContentAlignment="Top" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
