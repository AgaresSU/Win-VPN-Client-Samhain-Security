                                          Unchecked="AppSettingCheckBox_Changed" />

                                <CheckBox x:Name="AutoConnectLastProfileCheckBox"
                                          Grid.Column="1"
                                          Content="Подключать последний профиль"
                                          Foreground="{StaticResource TextBrush}"
                                          Checked="AppSettingCheckBox_Changed"
                                          Unchecked="AppSettingCheckBox_Changed" />

                                <CheckBox x:Name="AutoReconnectCheckBox"
                                          Grid.Row="1"
                                          Margin="0,10,0,0"
                                          Content="Восстанавливать подключение"
                                          Foreground="{StaticResource TextBrush}"
                                          Checked="AppSettingCheckBox_Changed"
                                          Unchecked="AppSettingCheckBox_Changed" />

                                <CheckBox x:Name="AutoFailoverCheckBox"
                                          Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="0,10,0,0"
                                          Content="Пробовать другой сервер"
                                          Foreground="{StaticResource TextBrush}"
                                          Checked="AppSettingCheckBox_Changed"
                                          Unchecked="AppSettingCheckBox_Changed" />

                                <CheckBox x:Name="AutoBestServerCheckBox"
                                          Grid.Row="2"
                                          Margin="0,10,0,0"
                                          Content="Подключаться к лучшему"
                                          Foreground="{StaticResource TextBrush}"
                                          Checked="AppSettingCheckBox_Changed"
                                          Unchecked="AppSettingCheckBox_Changed" />

                                <CheckBox x:Name="AutoRefreshSubscriptionsCheckBox"
                                          Grid.Row="2"
                                          Grid.Column="1"
                                          Margin="0,10,0,0"
                                          Content="Обновлять подписки"
                                          Foreground="{StaticResource TextBrush}"
                                          Checked="AppSettingCheckBox_Changed"
                                          Unchecked="AppSettingCheckBox_Changed" />

                                <CheckBox x:Name="ConnectionWatchdogCheckBox"
                                          Grid.Row="3"
                                          Margin="0,10,0,0"
                                          Content="Следить за подключением"
                                          Foreground="{StaticResource TextBrush}"
                                          Checked="AppSettingCheckBox_Changed"
                                          Unchecked="AppSettingCheckBox_Changed" />
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Название" Style="{StaticResource LabelTextStyle}" />
                                <TextBox x:Name="NameTextBox" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Протокол" Style="{StaticResource LabelTextStyle}" />
                                <DockPanel>
                                    <ComboBox x:Name="ProtocolComboBox"
                                              DockPanel.Dock="Left"
                                              Width="134"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectionChanged="ProtocolComboBox_SelectionChanged" />
                                    <Border x:Name="EngineStatusBadge"
                                            Background="{StaticResource SuccessBrush}"
                                            Padding="10,7"
                                            Margin="8,0,0,0"
                                            MinHeight="38">
                                        <TextBlock x:Name="EngineStatusTextBlock"
                                                   Text="Ready"
                                                   Foreground="{StaticResource SuccessTextBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Порт" Style="{StaticResource LabelTextStyle}" />
                                <TextBox x:Name="ServerPortTextBox" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Сервер" Style="{StaticResource LabelTextStyle}" />
                            <TextBox x:Name="ServerTextBox" />
                        </StackPanel>

                        <Expander x:Name="AdvancedSettingsExpander"
                                  Header="Расширенные настройки"
                                  Margin="0,18,0,0"
                                  Expanded="AdvancedSettingsExpander_Changed"
                                  Collapsed="AdvancedSettingsExpander_Changed">
                            <StackPanel Margin="0,14,0,0">
                        <Border Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                Padding="14"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="108" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="118" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="118" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Движки"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="EngineManagerStatusTextBlock"
                                                   Text="Проверка не запускалась"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button x:Name="CheckEnginesButton"
                                            Grid.Column="2"
                                            Content="Проверить"
                                            VerticalAlignment="Center"
                                            Click="CheckEnginesButton_Click" />
                                    <Button x:Name="UseEngineButton"
                                            Grid.Column="4"
                                            Content="Использовать"
                                            VerticalAlignment="Center"
                                            Click="UseEngineButton_Click" />
                                    <Button x:Name="OpenEnginesFolderButton"
                                            Grid.Column="6"
                                            Content="Папка"
                                            VerticalAlignment="Center"
                                            Click="OpenEnginesFolderButton_Click" />
                                </Grid>

                                <ListView x:Name="EngineCatalogListView"
                                          Height="128"
                                          Margin="0,12,0,0"
                                          BorderBrush="{StaticResource LineBrush}"
                                          BorderThickness="1"
                                          SelectionChanged="EngineCatalogListView_SelectionChanged">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Движок"
                                                            Width="120"
                                                            DisplayMemberBinding="{Binding Name}" />
                                            <GridViewColumn Header="Статус"
                                                            Width="90"
                                                            DisplayMemberBinding="{Binding Status}" />
                                            <GridViewColumn Header="Версия"
                                                            Width="160"
                                                            DisplayMemberBinding="{Binding Version}" />
                                            <GridViewColumn Header="Путь"
                                                            Width="360"
                                                            DisplayMemberBinding="{Binding Path}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Grid x:Name="EnginePathPanel" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="EnginePathLabel"
                                           Text="Движок"
                                           Style="{StaticResource LabelTextStyle}" />
                                <TextBox x:Name="EnginePathTextBox"
                                         TextChanged="EnginePathTextBox_TextChanged" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="Обзор"
                                    VerticalAlignment="Bottom"
                                    Click="BrowseEngineButton_Click" />
                        </Grid>

                        <StackPanel x:Name="NativePanel" Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Тип туннеля" Style="{StaticResource LabelTextStyle}" />
                                    <ComboBox x:Name="TunnelTypeComboBox"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Пользователь" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="UserNameTextBox" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Пароль" Style="{StaticResource LabelTextStyle}" />
                                    <PasswordBox x:Name="PasswordBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="L2TP PSK" Style="{StaticResource LabelTextStyle}" />
                                    <PasswordBox x:Name="L2tpPskPasswordBox" />
                                </StackPanel>
                            </Grid>

                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Маршрутизация приложений"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,8" />

                            <TextBlock Text="Режим" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox x:Name="AppRoutingModeComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectionChanged="AppRoutingModeComboBox_SelectionChanged" />

                            <TextBlock Text="Приложения"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,12,0,0" />
                            <TextBox x:Name="AppRoutingPathsTextBox"
                                     Height="72"
                                     AcceptsReturn="True"
                                     TextChanged="AppRoutingPathsTextBox_TextChanged"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" />
                            <TextBlock x:Name="AppRoutingHintTextBlock"
                                       Text="Режим на весь компьютер не требует списка приложений."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel x:Name="VlessRealityPanel" Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="VLESS URI" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="VlessUriTextBox" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Импорт"
                                        VerticalAlignment="Bottom"
                                        Click="ImportVlessButton_Click" />
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="UUID" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="VlessUuidTextBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Flow" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="VlessFlowTextBox" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Reality SNI" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityServerNameTextBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Fingerprint" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityFingerprintTextBox" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Reality public key" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityPublicKeyTextBox" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Short ID" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="RealityShortIdTextBox" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="TunnelConfigPanel" Margin="0,18,0,0">
                            <TextBlock x:Name="TunnelConfigLabel"
                                       Text="WireGuard .conf"
                                       Style="{StaticResource LabelTextStyle}" />
                            <TextBox x:Name="TunnelConfigTextBox"
                                     Height="190"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     VerticalContentAlignment="Top" />
                        </StackPanel>

                        <Border Height="1"
                                Background="{StaticResource LineBrush}"
                                Margin="0,20,0,18" />

                        <StackPanel>
                            <TextBlock Text="Защита"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <CheckBox x:Name="KillSwitchCheckBox"
                                              Content="Kill switch"
                                              Foreground="{StaticResource TextBrush}"
                                              Margin="0,0,0,10" />
                                    <CheckBox x:Name="DnsLeakProtectionCheckBox"
                                              Content="DNS leak protection"
                                              Foreground="{StaticResource TextBrush}"
                                              Margin="0,0,0,10" />
                                    <CheckBox x:Name="AllowLanTrafficCheckBox"
                                              Content="Локальная сеть"
                                              Foreground="{StaticResource TextBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="DNS servers" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="DnsServersTextBox" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,14,0,0">
                                <Button x:Name="PreviewProtectionButton"
                                        Content="План"
                                        Click="PreviewProtectionButton_Click"
                                        Margin="0,0,8,0" />
                                <Button x:Name="ProtectionStatusButton"
                                        Content="Проверить"
                                        Click="ProtectionStatusButton_Click"
                                        Margin="0,0,8,0" />
                                <Button x:Name="RemoveProtectionButton"
                                        Content="Снять"
                                        Click="RemoveProtectionButton_Click"
                                        Margin="0,0,8,0" />
                                <Button x:Name="ResetProtectionButton"
                                        Content="Сброс"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="ResetProtectionButton_Click"
                                        Margin="0,0,8,0" />
                                <Button x:Name="ApplyProtectionButton"
                                        Content="Применить"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="ApplyProtectionButton_Click" />
                            </StackPanel>
                        </StackPanel>
                            </StackPanel>
                        </Expander>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,18,0,0">
                            <Button x:Name="SaveProfileButton"
                                    Content="Сохранить"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveProfileButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Padding="18"
                    Margin="0,18,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Журнал"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Margin="0,0,0,10" />
                    <TextBox x:Name="LogTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="#1B1F2A"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalContentAlignment="Top" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="DailyStatusPanel"
                Grid.Column="2"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1,0,0,0"
                Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Height="410" Margin="-24,-24,-24,24" ClipToBounds="True">
                        <Border Background="#151820" />
                        <Path Data="M 0 80 C 90 10 245 20 430 0 L 430 410 L 0 410 Z"
                              Fill="#11141A"
                              Opacity="0.86" />
                        <Path Data="M 0 410 C 120 340 200 300 430 308 L 430 410 Z"
                              Fill="#201018"
                              Opacity="0.62" />

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Samhain Security"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Margin="0,0,0,8" />

                            <Border x:Name="DailyConnectionBadge"
                                    Background="{StaticResource WarningBrush}"
                                    Padding="14,7"
                                    HorizontalAlignment="Center"
                                    MinWidth="128"
                                    Margin="0,0,0,18">
                                <TextBlock x:Name="DailyConnectionStateTextBlock"
                                           Text="Ожидание"
                                           Foreground="{StaticResource WarningTextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextAlignment="Center" />
                            </Border>

                            <Grid Width="250" Height="250" Margin="0,0,0,16">
                                <Ellipse Stroke="#2B1730"
                                         StrokeThickness="2"
                                         Opacity="0.95" />
                                <Ellipse Width="196"
                                         Height="196"
                                         Stroke="#374052"
                                         StrokeThickness="26"
                                         Opacity="0.84"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Ellipse Width="148"
                                         Height="148"
                                         Fill="#1A1E29"
                                         Stroke="#475169"
                                         StrokeThickness="3"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Button x:Name="ConnectButton"
                                        Content="⏻"
                                        Style="{StaticResource PowerButtonStyle}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="ConnectButton_Click"
                                        ToolTip="Подключить" />
                            </Grid>

                            <Button x:Name="DisconnectButton"
                                    Content="Отключить"
                                    Width="164"
                                    HorizontalAlignment="Center"
                                    Click="DisconnectButton_Click" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Выбрано"
                               Style="{StaticResource DailyLabelTextStyle}"
                               TextAlignment="Center" />
                    <TextBlock x:Name="DailyProfileTextBlock"
                               Text="Профиль не выбран"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6" />
                    <TextBlock x:Name="DailyRouteTextBlock"
                               Text="Маршрут не выбран"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,24">
                        <Border Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentMutedBrush}"
                                BorderThickness="1"
                                Padding="12,5"
                                Margin="0,0,8,0">
                            <TextBlock Text="Proxy" Style="{StaticResource ModeChipTextStyle}" />
                        </Border>
                        <Border Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentMutedBrush}"
                                BorderThickness="1"
                                Padding="12,5">
                            <TextBlock Text="TUN" Style="{StaticResource ModeChipTextStyle}" />
                        </Border>
                    </StackPanel>

                    <Border Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                                <TextBlock Text="Протокол" Style="{StaticResource DailyLabelTextStyle}" />
                                <TextBlock x:Name="DailyProtocolTextBlock"
                                           Text="Windows Native"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,12">
                                <TextBlock Text="Защита" Style="{StaticResource DailyLabelTextStyle}" />
                                <TextBlock x:Name="DailyProtectionTextBlock"
                                           Text="Выключена"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <TextBlock x:Name="DailyServiceTextBlock"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="Служба: проверка"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />

                            <TextBlock x:Name="DailyAutoModeTextBlock"
                                       Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="Автозапуск: выкл"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <ProgressBar x:Name="ConnectionProgressBar"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Margin="0,0,0,10"
                                 Visibility="Collapsed" />
                    <TextBlock x:Name="ConnectionDetailTextBlock"
                               Text="Готово"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="HealthSummaryTextBlock"
                               Text="Здоровье: нет данных"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="HistorySummaryTextBlock"
                               Text="История: пока пусто"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />

                    <Border Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="ReadinessSummaryTextBlock"
                                       Text="Среда: проверка не запускалась"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="CheckReadinessButton"
                                        Content="Среда"
                                        Click="CheckReadinessButton_Click" />
                                <Button x:Name="RepairReadinessButton"
                                        Grid.Column="2"
                                        Content="Исправить"
                                        Click="RepairReadinessButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
