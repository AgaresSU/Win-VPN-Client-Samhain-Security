<Window x:Class="SamhainSecurity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Samhain Security"
        Icon="Assets/SamhainSecurity.ico"
        Height="820"
        Width="1320"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#090B0F"
        Loaded="Window_Loaded"
        Activated="Window_Activated">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#090B0F" />
        <SolidColorBrush x:Key="AccentBrush" Color="#C9343D" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#251015" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#6F2229" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171A20" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#11141A" />
        <SolidColorBrush x:Key="ControlBrush" Color="#20242C" />
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#2A171D" />
        <SolidColorBrush x:Key="ControlPressedBrush" Color="#36141B" />
        <SolidColorBrush x:Key="ControlDisabledBrush" Color="#15181E" />
        <SolidColorBrush x:Key="LineBrush" Color="#333842" />
        <SolidColorBrush x:Key="LineHotBrush" Color="#722832" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A69DA0" />
        <SolidColorBrush x:Key="TextBrush" Color="#ECE7E2" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#0B0E13" />
        <SolidColorBrush x:Key="NavTextBrush" Color="#CBC3C4" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#17251F" />
        <SolidColorBrush x:Key="SuccessTextBrush" Color="#83D0A5" />
        <SolidColorBrush x:Key="WarningBrush" Color="#2A2113" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#D4A65A" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#351419" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#F07F86" />

        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#11141A" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#20242C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#6F2229" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#ECE7E2" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#ECE7E2" />
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#81787B" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="DailyLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7D7174" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource ControlBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentMutedBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource LineHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxChrome" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                                <Setter Property="Foreground" Value="#81787B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource ControlBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentMutedBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="PasswordBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PasswordBoxChrome" Property="BorderBrush" Value="{StaticResource LineHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="PasswordBoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PasswordBoxChrome" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                                <Setter Property="Foreground" Value="#81787B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ComboToggleChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Path x:Name="ComboArrow"
                                  Width="8"
                                  Height="5"
                                  Fill="{StaticResource MutedTextBrush}"
                                  Data="M 0 0 L 4 5 L 8 0 Z"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboToggleChrome" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                <Setter TargetName="ComboToggleChrome" Property="BorderBrush" Value="{StaticResource LineHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ComboToggleChrome" Property="Background" Value="{StaticResource ControlPressedBrush}" />
                                <Setter TargetName="ComboToggleChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ComboArrow" Property="Fill" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboToggleChrome" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                                <Setter TargetName="ComboArrow" Property="Fill" Value="#81787B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource ControlBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource ComboBoxToggleButtonStyle}"
                                          ClickMode="Press" />
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              IsHitTestVisible="False" />
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource AccentMutedBrush}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#81787B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboItemChrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboItemChrome" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboItemChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#81787B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource ControlBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource LineHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource ControlPressedBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                <Setter Property="Foreground" Value="#81787B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource NavTextBrush}" />
        </Style>

        <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="56" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource NavTextBrush}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ModeChipTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PowerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="164" />
            <Setter Property="Height" Value="164" />
            <Setter Property="MinHeight" Value="164" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="52" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PowerChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="82"
                                BorderBrush="{StaticResource LineHotBrush}"
                                BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PowerChrome" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                                <Setter TargetName="PowerChrome" Property="BorderBrush" Value="{StaticResource LineBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckChrome"
                                    Width="16"
                                    Height="16"
                                    Background="{StaticResource ControlBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 3 8 L 6.5 11.5 L 13 4"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Square"
                                      StrokeEndLineCap="Square"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource LineHotBrush}" />
                                <Setter TargetName="CheckChrome" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#81787B" />
                                <Setter TargetName="CheckChrome" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome"
                                Background="#3A2026"
                                BorderBrush="{StaticResource LineHotBrush}"
                                BorderThickness="1" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource AccentMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{StaticResource PanelAltBrush}" Width="12">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource ScrollRepeatButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource ScrollRepeatButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{StaticResource PanelAltBrush}" Height="12">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource ScrollRepeatButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource ScrollRepeatButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource LineHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem" BasedOn="{StaticResource DarkListBoxItemStyle}" />

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ListViewItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ListViewItemChrome" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ListViewItemChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="ListViewItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ServerRowListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#202225" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ServerRowChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ServerRowChrome" Property="Background" Value="#2A2427" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ServerRowChrome" Property="Background" Value="#3A3132" />
                                <Setter TargetName="ServerRowChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ServerRowChrome" Property="BorderThickness" Value="4,0,0,1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#81787B" />
                                <Setter TargetName="ServerRowChrome" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="HeaderChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderChrome" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineHotBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="86" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="430" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel Margin="0">
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0" HorizontalAlignment="Center">
                    <Image Source="Assets/SamhainSecurity.png"
                           Width="42"
                           Height="42"
                           Stretch="UniformToFill"
                           ToolTip="Samhain Security" />
                    <TextBlock x:Name="VersionTextBlock"
                               Text="0.0.1"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,12" />

                    <Button x:Name="NewProfileButton"
                            Content="+"
                            ToolTip="Добавить конфигурацию"
                            Style="{StaticResource RailButtonStyle}"
                            Click="NewProfileButton_Click" />

                    <Button x:Name="AllServersCategoryButton"
                            Content="◎"
                            Tag="all"
                            ToolTip="Все серверы"
                            Style="{StaticResource RailButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="FavoriteServersCategoryButton"
                            Content="★"
                            Tag="favorite"
                            ToolTip="Избранные"
                            Style="{StaticResource RailButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="FastServersCategoryButton"
                            Content="↯"
                            Tag="fast"
                            ToolTip="Быстрые"
                            Style="{StaticResource RailButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="RecentServersCategoryButton"
                            Content="↺"
                            Tag="recent"
                            ToolTip="Последние"
                            Style="{StaticResource RailButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="VlessServersCategoryButton"
                            Content="V"
                            Tag="vless"
                            ToolTip="VLESS Reality"
                            Style="{StaticResource RailButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                    <Button x:Name="AwgServersCategoryButton"
                            Content="A"
                            Tag="awg"
                            ToolTip="AmneziaWG"
                            Style="{StaticResource RailButtonStyle}"
                            Click="ServerCategoryButton_Click" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,14" HorizontalAlignment="Center">
                    <Button x:Name="DeleteProfileButton"
                            Content="×"
                            ToolTip="Удалить выбранную конфигурацию"
                            Style="{StaticResource RailButtonStyle}"
                            Foreground="{StaticResource ErrorTextBrush}"
                            Click="DeleteProfileButton_Click" />
                    <TextBlock Text="i"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="SemiBold"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               ToolTip="О программе и справка" />
                </StackPanel>

                <ListBox x:Name="ProfilesListBox"
                         Visibility="Collapsed"
                         SelectionChanged="ProfilesListBox_SelectionChanged" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="190" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="ServerCatalogTitleTextBlock"
                               Text="Все серверы"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Готово"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RunAsAdminButton"
                            Content="Админ"
                            Click="RunAsAdminButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="ServiceButton"
                            Content="Служба"
                            Click="ServiceButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="DiagnosticsButton"
                            Content="Диагностика"
                            Click="DiagnosticsButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="ExportDiagnosticsButton"
                            Content="Экспорт"
                            Click="ExportDiagnosticsButton_Click"
                            Margin="0,0,8,0" />
                    <Button x:Name="RefreshStatusButton"
                            Content="Статус"
                            Click="RefreshStatusButton_Click" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Padding="22">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border x:Name="FirstRunPanel"
                                Background="{StaticResource SuccessBrush}"
                                BorderBrush="#2D7D69"
                                BorderThickness="1"
                                Padding="16"
                                Margin="0,0,0,20"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="86" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Быстрый старт"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Вставьте ссылку подключения, обновите подписку и нажмите Подключить."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Из буфера"
                                        VerticalAlignment="Center"
                                        Click="FirstRunPasteButton_Click" />

                                <Button Grid.Column="4"
                                        Content="Скрыть"
                                        VerticalAlignment="Center"
                                        Click="DismissFirstRunButton_Click" />
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                Padding="14"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Подписка"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="88" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ссылка подключения" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox x:Name="SubscriptionUrlTextBox" />
                                    </StackPanel>

                                    <Button x:Name="RefreshSubscriptionButton"
                                            Grid.Column="2"
                                            Content="Обновить"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            VerticalAlignment="Bottom"
                                            Click="RefreshSubscriptionButton_Click" />

                                    <Button x:Name="RefreshAllSubscriptionsButton"
                                            Grid.Column="4"
                                            Content="Все"
                                            VerticalAlignment="Bottom"
                                            Click="RefreshAllSubscriptionsButton_Click" />

                                    <Button x:Name="PasteSubscriptionButton"
                                            Grid.Column="6"
                                            Content="Буфер"
                                            VerticalAlignment="Bottom"
                                            Click="PasteSubscriptionButton_Click" />

                                    <Button x:Name="DeleteSubscriptionButton"
                                            Grid.Column="8"
                                            Content="Удалить"
                                            Style="{StaticResource DangerButtonStyle}"
                                            VerticalAlignment="Bottom"
                                            Click="DeleteSubscriptionButton_Click" />
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="84" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Сохраненные подписки" Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="SubscriptionSelectorComboBox"
                                                  DisplayMemberPath="SelectorName"
                                                  SelectionChanged="SubscriptionSelectorComboBox_SelectionChanged" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Сервер" Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="ServerSelectorComboBox"
                                                  SelectionChanged="ServerSelectorComboBox_SelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding StatusLabel}"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12"
                                                                       Margin="10,0,0,0" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding Details}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding MenuLabel}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <Button x:Name="FavoriteServerButton"
                                            Grid.Column="4"
                                            Content="Избранное"
                                            VerticalAlignment="Bottom"
                                            Click="FavoriteServerButton_Click" />

                                    <Button x:Name="BestServerButton"
                                            Grid.Column="6"
                                            Content="Лучший"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            VerticalAlignment="Bottom"
                                            Click="BestServerButton_Click" />

                                    <Button x:Name="ProbeServersButton"
                                            Grid.Column="8"
                                            Content="Проверить"
                                            VerticalAlignment="Bottom"
                                            Click="ProbeServersButton_Click" />

                                    <Button x:Name="ResetServerHealthButton"
                                            Grid.Column="10"
                                            Content="Сброс"
                                            VerticalAlignment="Bottom"
                                            Click="ResetServerHealthButton_Click" />
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="RecommendedServerButton"
                                            Grid.Column="0"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="12,10"
                                            Click="RecommendedServerButton_Click">
                                        <StackPanel>
                                            <TextBlock Text="Рекомендуем"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="RecommendedServerNameTextBlock"
                                                       Text="Нет серверов"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecommendedServerDetailTextBlock"
                                                       Text="Обновите подписку"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecommendedServerReasonTextBlock"
                                                       Text="Нет данных"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="FavoriteRecommendationButton"
                                            Grid.Column="2"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="12,10"
                                            Click="FavoriteRecommendationButton_Click">
                                        <StackPanel>
                                            <TextBlock Text="Избранный"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="FavoriteRecommendationNameTextBlock"
                                                       Text="Не выбран"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="FavoriteRecommendationDetailTextBlock"
                                                       Text="Отметьте сервер"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="FavoriteRecommendationReasonTextBlock"
                                                       Text="Нет данных"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="RecentServerButton"
                                            Grid.Column="4"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="12,10"
                                            Click="RecentServerButton_Click">
                                        <StackPanel>
                                            <TextBlock Text="Последний"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="RecentServerNameTextBlock"
                                                       Text="Пока пусто"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecentServerDetailTextBlock"
                                                       Text="После успешного подключения"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock x:Name="RecentServerReasonTextBlock"
                                                       Text="Нет данных"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="4" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="92" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Поиск сервера" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox x:Name="ServerSearchTextBox"
                                                 KeyDown="ServerSearchTextBox_KeyDown"
                                                 TextChanged="ServerCatalogFilter_Changed" />
                                    </StackPanel>

                                    <CheckBox x:Name="FavoriteServersOnlyCheckBox"
                                              Grid.Column="2"
                                              Content="Только избранные"
                                              Foreground="{StaticResource TextBrush}"
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,0,10"
                                              Checked="ServerCatalogFilter_Changed"
                                              Unchecked="ServerCatalogFilter_Changed" />

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Сортировка" Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="ServerSortComboBox"
                                                  SelectionChanged="ServerSortComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Умная" Tag="smart" />
                                            <ComboBoxItem Content="Быстрые" Tag="latency" />
                                            <ComboBoxItem Content="Избранные" Tag="favorite" />
                                            <ComboBoxItem Content="Недавние" Tag="recent" />
                                            <ComboBoxItem Content="По имени" Tag="name" />
                                        </ComboBox>
                                    </StackPanel>

                                    <Button x:Name="ClearServerFiltersButton"
                                            Grid.Column="6"
                                            Content="Сбросить"
                                            VerticalAlignment="Bottom"
                                            Click="ClearServerFiltersButton_Click" />
                                </Grid>

                                <ListView x:Name="ServersListView"
                                          Grid.Row="5"
                                          Height="300"
                                          Margin="0,12,0,0"
                                          Background="{StaticResource PanelBrush}"
                                          Foreground="{StaticResource TextBrush}"
                                          BorderBrush="{StaticResource LineBrush}"
                                          BorderThickness="1"
                                          ItemContainerStyle="{StaticResource ServerRowListViewItemStyle}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          KeyDown="ServersListView_KeyDown"
                                          MouseDoubleClick="ServersListView_MouseDoubleClick"
                                          PreviewMouseRightButtonDown="ServersListView_PreviewMouseRightButtonDown"
                                          SelectionChanged="ServersListView_SelectionChanged">
                                    <ListView.ContextMenu>
                                        <ContextMenu Opened="ServersListContextMenu_Opened">
                                            <MenuItem Header="Подключить"
                                                      Click="ServerContextConnectMenuItem_Click" />
                                            <MenuItem x:Name="ServerContextFavoriteMenuItem"
                                                      Header="В избранное"
                                                      Click="ServerContextFavoriteMenuItem_Click" />
                                            <MenuItem Header="Копировать адрес"
                                                      Click="ServerContextCopyEndpointMenuItem_Click" />
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ToolTip="{Binding Endpoint}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="98" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="32"
                                                        Height="32"
                                                        CornerRadius="16"
                                                        Background="{StaticResource AccentSoftBrush}"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding BadgeText}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,14,0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ProtocolLabel}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text=" / "
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding MenuLabel}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontSize="13"
                                                               HorizontalAlignment="Right" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="3"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding FavoriteMark}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="16"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding ActionMark}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="16"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock x:Name="ServerCatalogSummaryTextBlock"
                                           Grid.Row="6"
                                           Text="Серверов: 0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,0" />

                                <Grid Grid.Row="7" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="116" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Название источника" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox x:Name="SubscriptionNameTextBox" />
                                    </StackPanel>

                                    <Button x:Name="RenameSubscriptionButton"
                                            Grid.Column="2"
                                            Content="Переим."
                                            VerticalAlignment="Bottom"
                                            Click="RenameSubscriptionButton_Click" />

                                    <Button x:Name="ToggleSubscriptionButton"
                                            Grid.Column="4"
                                            Content="Выключить"
                                            VerticalAlignment="Bottom"
                                            Click="ToggleSubscriptionButton_Click" />
                                </Grid>

                                <ListBox x:Name="SubscriptionSourcesListBox"
                                         Grid.Row="8"
                                         Height="112"
                                         Margin="0,12,0,0"
                                         BorderBrush="{StaticResource LineBrush}"
                                         BorderThickness="1"
                                         SelectionChanged="SubscriptionSourcesListBox_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource DarkListBoxItemStyle}">
                                            <Setter Property="Padding" Value="10,8" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding MaskedUrl}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding DisplayStatus}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock x:Name="SubscriptionStatusTextBlock"
                                           Grid.Row="9"
                                           Text="Подписка не добавлена"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,9,0,0"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                Padding="14"
                                Margin="0,0,0,20">
